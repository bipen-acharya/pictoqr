# ─────────────────────────────────────────────────────────────────────
#  PictoQR · Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public base URL of your deployment (used in QR codes and the /api/upload response).
# Must be the full HTTPS URL in production — phones cannot reach localhost.
# Example: BASE_URL=https://pictoqr-production.up.railway.app
BASE_URL=http://localhost:3000

# Maximum upload file size in bytes (default: 25 MB)
MAX_FILE_SIZE=26214400

# ── Cloudflare R2 (persistent file storage) ───────────────────────────
# All five R2 vars must be set for R2 to be active.
# If any are missing the app falls back to local /uploads (ephemeral on Railway).
#
# How to get these values:
#   1. Log in to dash.cloudflare.com → R2 Object Storage → Create bucket
#   2. On the bucket → Settings → Enable "Public access" (or set up a custom domain)
#   3. In R2 overview → Manage API tokens → Create an API token with
#      "Object Read & Write" permission scoped to your bucket
#   4. Copy Account ID from the R2 overview page (top-right of the R2 section)

# Your Cloudflare account ID (found on the R2 overview page)
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 API token credentials (from the API token you created above)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# The name of your R2 bucket (e.g. pictoqr-files)
R2_BUCKET_NAME=pictoqr-files

# Public URL for your bucket — either the R2.dev subdomain Cloudflare assigns
# when you enable public access, or your own custom domain if you've set one up.
# Example (R2.dev subdomain): https://pub-abc123def456.r2.dev
# Example (custom domain):    https://files.pictoqr.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
